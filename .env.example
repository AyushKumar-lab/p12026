# =============================================================================
# TEMPLATE ONLY — Next.js does NOT read this file at runtime.
# Copy to ".env" and/or ".env.local" and replace placeholders with real values.
# See docs/API_KEYS.md for where to get each key.
# =============================================================================

# --- Next.js (client-exposed only if NEXT_PUBLIC_*) ---
NEXT_PUBLIC_MAPBOX_API_KEY=YOUR_MAPBOX_TOKEN_HERE
NEXT_PUBLIC_MAPBOX_TOKEN=YOUR_MAPBOX_TOKEN_HERE
NEXT_PUBLIC_MAPBOX_STYLE=mapbox/satellite-streets-v12

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

NEXT_PUBLIC_API_URL=
NEXT_PUBLIC_PYTHON_BACKEND_URL=http://localhost:5000

# --- Server / API routes / collectors ---
SUPABASE_SERVICE_ROLE_KEY=
SEED_SECRET=

# --- Optional paid enrichment ---
GOOGLE_PLACES_API_KEY=

# --- Flask backend (optional) ---
FLASK_DEBUG=false
PORT=5000
HOST=0.0.0.0
