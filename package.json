{
  "name": "business-location-intelligence",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:3000": "next dev -p 3000",
    "clean:next": "node scripts/clean-next.js",
    "dev:fresh": "npm run clean:next && next dev -p 3000",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "db:migrate": "prisma migrate dev",
    "db:generate": "prisma generate",
    "db:studio": "prisma studio",
    "db:seed": "ts-node prisma/seed.ts",
    "db:reset": "prisma migrate reset --force && npm run db:seed",
    "train:ml": "python scripts/run_local_training.py",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@headlessui/react": "^2.0.4",
    "@hookform/resolvers": "^3.6.0",
    "@prisma/client": "^6.19.2",
    "@react-google-maps/api": "^2.19.3",
    "@supabase/supabase-js": "^2.99.1",
    "@types/leaflet": "^1.9.21",
    "bcryptjs": "^3.0.3",
    "clsx": "^2.1.1",
    "framer-motion": "^11.2.10",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.394.0",
    "mapbox-gl": "^3.20.0",
    "next": "14.2.5",
    "prisma": "^6.19.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.51.5",
    "react-leaflet": "^4.2.1",
    "recharts": "^2.12.7",
    "tailwind-merge": "^2.3.0",
    "zod": "^3.23.8",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.14.2",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.19",
    "eslint": "^8.57.0",
    "eslint-config-next": "14.2.5",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.4",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5"
  }
